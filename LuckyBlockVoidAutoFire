-- // Dragging
local dragging, dragStart, startPos, startShadow

local function syncShadow()
	shadow.Position = UDim2.new(
		main.Position.X.Scale,
		main.Position.X.Offset + 6,
		main.Position.Y.Scale,
		main.Position.Y.Offset + 6
	)
end

titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = main.Position
		startShadow = shadow.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		main.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
		shadow.Position = UDim2.new(
			startShadow.X.Scale, startShadow.X.Offset + delta.X,
			startShadow.Y.Scale, startShadow.Y.Offset + delta.Y
		)
	end
end)

