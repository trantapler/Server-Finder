function Monitor.SetStatus(text, subtext)
	statusLabel.Text = string.format("[ %s ]", string.upper(text or "IDLE"))
	if subtext then
		subStatus.Text = subtext
	end
end

function Monitor.SetProgress(ratio)
	ratio = math.clamp(ratio or 0, 0, 1)
	tween(barFill, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.new(ratio, 0, 1, 0),
	})
	progressText.Text = string.format("PROGRESS: %d%%", math.floor(ratio * 100))
end

function Monitor.Log(message, level)
	level = level or "info"
	local stamp = os.date("%H:%M:%S")
	local line = label(logScroll, {
		Size = UDim2.new(1, -8, 0, 16),
		Text = string.format("[%s] %s", stamp, tostring(message)),
		TextColor3 = LOG_COLORS[level] or LOG_COLORS.info,
		TextSize = 11,
		TextXAlignment = Enum.TextXAlignment.Left,
		LayoutOrder = #logLines + 1,
	})
	table.insert(logLines, line)
	if #logLines > MAX_LOG then
		logLines[1]:Destroy()
		table.remove(logLines, 1)
	end
	logScroll.CanvasSize = UDim2.new(0, 0, 0, logLayout.AbsoluteContentSize.Y + 12)
	logScroll.CanvasPosition = Vector2.new(0, math.max(0, logScroll.CanvasSize.Y.Offset))
end

function Monitor.SetToggle(name, enabled)
	if toggleStates[name] == nil then return end
	toggleStates[name] = not not enabled
	local btn = toggleButtons[name]
	if btn then
		local on = toggleStates[name]
		btn.Text = on and "ENABLED" or "DISABLED"
		btn.TextColor3 = on and THEME.ok or THEME.danger
		stroke(btn, on and THEME.ok or THEME.danger, 1, 0.35)
	end
end

function Monitor.OnToggle(name, callback)
	if not toggleCallbacks[name] then
		toggleCallbacks[name] = {}
	end
	table.insert(toggleCallbacks[name], callback)
end

function Monitor.SetVisible(state)
	main.Visible = state
	shadow.Visible = state
end

function Monitor.SetMatrixEnabled(state)
	rainLayer.Visible = state
end

-- // Arm effect
local function playArmEffect()
	if arming then return end
	arming = true

	Monitor.Log("Systems arming...", "ok")
	rainBoost = 1

	-- Green flash
	armFlash.BackgroundTransparency = 0.55
	tween(armFlash, TweenInfo.new(0.55, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 1,
	})

	-- Border pulse
	mainStroke.Thickness = 1.2
	mainStroke.Color = THEME.accentGlow
	tween(mainStroke, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Thickness = 3.5,
		Transparency = 0,
	})
	task.delay(0.35, function()
		tween(mainStroke, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Thickness = 1.2,
			Transparency = 0.35,
			Color = THEME.accent,
		})
	end)

	-- Scan sweep
	armSweep.Visible = true
	armSweep.Position = UDim2.new(0, 0, 0, -6)
	tween(armSweep, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.new(0, 0, 1, 6),
	})
	task.delay(0.5, function()
		armSweep.Visible = false
	end)

	-- Button pulse
	toggleButton.Text = ">> ARMING <<"
	toggleButton.TextColor3 = THEME.accentGlow
	tween(toggleButton, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut, 3, true), {
		BackgroundTransparency = 0,
	})

	-- Status flicker
	task.spawn(function()
		local messages = { "INITIALIZING...", "SYNCING TARGETS...", "WEAPONS HOT..." }
		for _, msg in ipairs(messages) do
			Monitor.SetStatus("ARMING", msg)
			statusLabel.TextColor3 = THEME.accentGlow
			task.wait(0.18)
		end
	end)

	-- Title glitch
	task.spawn(function()
		local original = titleText.Text
		for _ = 1, 8 do
			titleText.Text = "VOID MONITOR // " .. randomMatrixChar() .. randomMatrixChar() .. randomMatrixChar()
			titleText.TextColor3 = THEME.accentGlow
			task.wait(0.05)
		end
		titleText.Text = original
		titleText.TextColor3 = THEME.accent
	end)

	task.delay(0.65, function()
		rainBoost = 0
		refreshAutoFireButton(true)
		Monitor.SetStatus("ARMED", "Auto fire enabled — watching target")
		statusLabel.TextColor3 = THEME.ok
		Monitor.Log("Systems armed", "ok")
		arming = false
	end)
end

local function playDisarmEffect()
	rainBoost = 0
	mainStroke.Color = THEME.accent
	mainStroke.Thickness = 1.2

	tween(toggleButton, TweenInfo.new(0.2), {
		BackgroundTransparency = 0.2,
	})

	refreshAutoFireButton(false)
	Monitor.SetStatus("IDLE", "Auto fire disabled")
	statusLabel.TextColor3 = THEME.ok
	Monitor.Log("Systems disarmed", "warn")
end

function refreshAutoFireButton(enabled)
	toggleButton.Text = enabled and "AUTO_FIRE: ENABLED" or "AUTO_FIRE: DISABLED"
	toggleButton.TextColor3 = enabled and THEME.ok or THEME.danger
	toggleStroke.Color = enabled and THEME.ok or THEME.danger
end

function setAutoFire(enabled)
	if arming then return end
	if enabled == isToggled then return end

	isToggled = enabled
	Monitor.SetToggle("Auto Fire", enabled)

	if enabled then
		playArmEffect()
	else
		playDisarmEffect()
	end

	for _, cb in ipairs(toggleCallbacks["Auto Fire"] or {}) do
		task.spawn(cb, enabled)
	end
end

