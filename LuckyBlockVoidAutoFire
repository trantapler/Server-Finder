-- // Matrix rain loop
for _, col in ipairs(rainColumns) do
	col.chars = {}
	for _ = 1, math.random(8, 14) do
		table.insert(col.chars, randomMatrixChar())
	end
	col.label.Text = table.concat(col.chars, "\n")
end

RunService.RenderStepped:Connect(function(dt)
	if not rainLayer.Visible then return end

	for _, col in ipairs(rainColumns) do
		local speedMul = 1 + (rainBoost * 1.8)
		col.offset += col.speed * speedMul * dt

		if col.offset > 260 then
			col.offset = math.random(-80, -20)
		end

		col.charTimer += dt
		local interval = col.charInterval / (1 + rainBoost * 0.8)
		if col.charTimer >= interval then
			col.charTimer = 0
			local index = math.random(1, #col.chars)
			col.chars[index] = randomMatrixChar()
			col.label.Text = table.concat(col.chars, "\n")
		end

		col.label.Position = UDim2.new(col.label.Position.X.Scale, col.label.Position.X.Offset, 0, col.offset)
		col.label.TextTransparency = (0.35 + (math.sin(os.clock() * 0.8 + col.speed) * 0.12)) - (rainBoost * 0.15)
	end
end)

