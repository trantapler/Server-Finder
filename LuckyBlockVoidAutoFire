-- // AUTO FIRE LOGIC
local function checkAndFire()
	if targetPart.BrickColor == BrickColor.new("Cyan") then
		if not isOnCooldown then
			Monitor.SetStatus("TARGET: CYAN DETECTED", "Cyan target locked")
		end

		if isToggled and not isOnCooldown then
			local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				isOnCooldown = true
				Monitor.SetStatus("EXECUTING", "Touch interest firing...")
				barFill.BackgroundColor3 = Color3.fromRGB(255, 255, 0)

				if type(firetouchinterest) == "function" then
					firetouchinterest(hrp, targetPart, 0)
					task.wait(0.05)
					firetouchinterest(hrp, targetPart, 1)
					Monitor.Log("Touch interest executed", "ok")
				else
					warn("firetouchinterest function not found in this environment context.")
					Monitor.Log("firetouchinterest not found", "error")
				end

				task.spawn(function()
					local startTime = os.time()
					while os.time() - startTime < cooldownDuration do
						local elapsed = os.time() - startTime
						local remaining = cooldownDuration - elapsed

						Monitor.SetStatus(
							string.format("COOLDOWN %02d:%02d", math.floor(remaining / 60), remaining % 60),
							"Waiting before next fire"
						)
						Monitor.SetProgress(1 - (elapsed / cooldownDuration))
						task.wait(1)
					end

					isOnCooldown = false
					Monitor.SetProgress(0)
					barFill.BackgroundColor3 = Color3.fromRGB(0, 255, 70)
					Monitor.SetStatus("READY", "System ready")
					Monitor.Log("Cooldown complete", "ok")
					checkAndFire()
				end)
			end
		end
	else
		if not isOnCooldown then
			Monitor.SetStatus("SEARCHING", "Scanning for cyan target...")
		end
	end
end

targetPart:GetPropertyChangedSignal("BrickColor"):Connect(checkAndFire)
checkAndFire()

return Monitor
