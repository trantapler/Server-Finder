local function makeTab(name)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.fromOffset(96, 26)
	btn.BackgroundColor3 = THEME.panel
	btn.BackgroundTransparency = 0.35
	btn.BorderSizePixel = 0
	btn.Text = string.upper(name)
	btn.TextColor3 = THEME.textDim
	btn.TextSize = 12
	btn.Font = Enum.Font.Code
	btn.AutoButtonColor = false
	btn.ZIndex = 6
	btn.Parent = tabBar
	corner(btn, 6)

	local page = Instance.new("Frame")
	page.Name = name
	page.Size = UDim2.new(1, -20, 1, -118)
	page.Position = UDim2.new(0, 10, 0, 78)
	page.BackgroundTransparency = 1
	page.Visible = false
	page.ZIndex = 6
	page.Parent = content
	pages[name] = { button = btn, frame = page }

	local function refreshTabs()
		for n, data in pairs(pages) do
			local active = n == activePage
			data.frame.Visible = active
			data.button.TextColor3 = active and THEME.accent or THEME.textDim
			data.button.BackgroundTransparency = active and 0.1 or 0.45
		end
	end

	btn.MouseButton1Click:Connect(function()
		activePage = name
		refreshTabs()
	end)

	refreshTabs()
	return page
end

